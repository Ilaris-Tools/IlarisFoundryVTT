{{log 'talent' this}}
<section class="{{cssClass}} flexcol" autocomplete="off">
    <header class="sheet-header">
        <div class="image-edit-container">
            <img src="{{item.img}}" data-action="editImage" title="{{item.name}}" height="64" width="64" />
            <i class="fas fa-edit image-edit-overlay"></i>
        </div>
        <h1>
            <input
                name="name"
                type="text"
                value="{{item.name}}"
                placeholder='{{localize "Talent"}}'
            />
        </h1>
    </header>

    <div class="form-group">
        <label><b>Fertigkeit:</b></label>
        {{#if hasOwner}}
        <select name="system.fertigkeit">
            {{selectOptions fertigkeit_list selected=item.system.fertigkeit}}
        </select>
        {{else}}
        <input
            name="system.fertigkeit"
            value="{{item.system.fertigkeit}}"
            type="text"
            data-dtype="String"
        />
        {{/if}}
    </div>
    <div class="form-group stacked description">
        <label><b>Beschreibung</b></label>
        <textarea rows="6" name="system.description">{{item.system.text}}</textarea>
    </div>
</section>
